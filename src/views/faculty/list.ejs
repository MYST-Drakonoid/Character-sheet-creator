<%- include('../partials/header') %>

<main class="page">
    <section class="content-card">
        <!-- Page Title -->
        <h1><%= title %></h1>

        <!-- Intro Text -->
        <p>
            Meet the brilliant minds of our intergalactic faculty directory.
            These professors teach everything from Computer Science to the
            History of the Crab Nebula.
        </p>

        <!-- Optional Sorting Links -->
        <div class="button-row">
            <a href="/faculty?sort=name" class="btn">Sort by Name</a>
            <a href="/faculty?sort=department" class="btn btn-secondary">Sort by Department</a>
            <a href="/faculty?sort=title" class="btn btn-secondary">Sort by Title</a>
        </div>

        <!-- Faculty Cards -->
        <div class="faculty-grid">
            <% faculty.forEach(member => { %>
                <article class="faculty-card">
                    <!-- Faculty Name links to detail page -->
                    <h2>
                        <a href="/faculty/<%= member.id %>">
                            <%= member.name %>
                        </a>
                    </h2>

                    <!-- Basic Information -->
                    <p>
                        <strong>Department:</strong>
                        <%= member.department %>
                    </p>

                    <p>
                        <strong>Title:</strong>
                        <%= member.title %>
                    </p>

                    <!-- Detail Link -->
                    <p>
                        <a href="/faculty/<%= member.id %>" class="btn">
                            View Profile
                        </a>
                    </p>
                </article>
            <% }) %>
        </div>

        <!-- Navigation Back to Main Site -->
        <p style="margin-top: 2rem; text-align: center;">
            <a href="/" class="btn btn-secondary">← Return to Home</a>
        </p>
    </section>
</main>

<%- include('../partials/footer') %>