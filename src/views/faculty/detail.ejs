<%- include('../partials/header') %>

<main class="page">
    <section class="content-card">
        <!-- Faculty Name -->
        <h1><%= faculty.name %></h1>

        <!-- Subtitle -->
        <p>
            <strong><%= faculty.title %></strong> in the
            <strong><%= faculty.department %></strong> Department
        </p>

        <!-- Detailed Faculty Information -->
        <div class="faculty-grid" style="grid-template-columns: 1fr;">
            <article class="faculty-card">
                <h2>Faculty Information</h2>

                <p>
                    <strong>Department:</strong>
                    <%= faculty.department %>
                </p>

                <p>
                    <strong>Title:</strong>
                    <%= faculty.title %>
                </p>

                <p>
                    <strong>Office:</strong>
                    <%= faculty.office %>
                </p>

                <p>
                    <strong>Phone:</strong>
                    <%= faculty.phone %>
                </p>

                <p>
                    <strong>Email:</strong>
                    <a href="mailto:<%= faculty.email %>">
                        <%= faculty.email %>
                    </a>
                </p>
            </article>
        </div>

        <!-- Navigation Links -->
        <div class="button-row" style="margin-top: 2rem;">
            <a href="/faculty" class="btn">← Back to Faculty Directory</a>
            <a href="/" class="btn btn-secondary">🏠 Home</a>
        </div>
    </section>
</main>

<%- include('../partials/footer') %>