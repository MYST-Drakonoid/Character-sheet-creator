<%- include('partials/header') %>

<main class="page">
    <section class="content-card">
        <h1><%= title %></h1>

        <p>
            We are a totally professional space crew dedicated to exploring the universe,
            getting lost, and pretending we meant to do that.
        </p>

        <h2>Our Crew</h2>

        <div class="card-grid">
            <article class="mini-card">
                <h3>Captain Wobble</h3>
                <p>Leader of the mission. Cannot read maps.</p>
            </article>

            <article class="mini-card">
                <h3>Professor Zorp</h3>
                <p>Alien scientist. Thinks humans are weird snacks.</p>
            </article>

            <article class="mini-card">
                <h3>Astro-Bob</h3>
                <p>Space mechanic. Fixes rockets with duct tape.</p>
            </article>
        </div>
    </section>
</main>

<%- include('partials/footer') %>