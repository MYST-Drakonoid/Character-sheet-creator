<%- include('partials/header') %>

<main>
    <div class="dashboard">
        <!-- Authenticated landing page for the signed-in user. -->
        <h1>Your Dashboard</h1>

        <!-- Short explanation of what the dashboard is for. -->
        <p>
            Manage your characters, custom content, and account settings.
        </p>

        <!-- Basic account information for the currently logged-in user. -->
        <div class="user-info">
            <h2>Your Account</h2>

            <div class="user-detail">
                <span class="label">Name:</span>
                <span class="value"><%= user.name %></span>
            </div>

            <div class="user-detail">
                <span class="label">Email:</span>
                <span class="value"><%= user.email %></span>
            </div>
        </div>

        <!-- Primary dashboard navigation for future character creator features. -->
        <nav>
            <ul>
                <li><a href="/characters">My Characters</a></li>
                <li><a href="/characters/new">Create Character</a></li>
                <li><a href="/content">Manage Content</a></li>
            </ul>
        </nav>

        <!-- DEVELOPMENT ONLY: Remove before production. -->
        <div class="session-debug">
            <h3>Session Information (For Learning Purposes)</h3>
            <p><em>This section shows your current session data for educational purposes.</em></p>
            <pre><%= JSON.stringify(sessionData, null, 2) %></pre>
            <p>
                <strong>If you see a password property in the above object you have a security vulnerability, fix it!</strong>
            </p>
        </div>

        <!-- Account/session action links. -->
        <div class="dashboard-actions">
            <a href="/logout" class="logout-button">Logout</a>
        </div>
    </div>
</main>

<%- include('partials/footer') %>