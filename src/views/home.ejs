<%- include('partials/header') %>

<main class="page home-page">
    <!-- Landing section for new and returning users. -->
    <section class="hero">
        <div>
            <!-- Short project label shown above the page title. -->
            <p class="eyebrow">D&amp;D Modular Character Creator</p>

            <h1><%= title %></h1>

            <!-- Main explanation of the app's purpose. -->
            <p>
                Create an account or log in to build, save, and manage your modular D&amp;D characters.
            </p>

            <!-- Primary account actions change depending on login status. -->
            <div class="button-row">
                <% if (typeof isLoggedIn !== 'undefined' && isLoggedIn) { %>
                    <a href="/dashboard" class="btn">Go to Dashboard</a>
                    <a href="/logout" class="btn btn-secondary">Logout</a>
                <% } else { %>
                    <a href="/login" class="btn">Log In</a>
                    <a href="/register" class="btn btn-secondary">Sign Up</a>
                <% } %>
            </div>
        </div>

        <!-- Brief feature summary for the character creator. -->
        <div class="status-card">
            <h2>Build Your Character</h2>
            <p>Save characters to your account.</p>
            <p>Create custom classes, spells, items, and rules.</p>
            <p>Keep each user&apos;s characters separate and organized.</p>
        </div>
    </section>
</main>

<%- include('partials/footer') %>