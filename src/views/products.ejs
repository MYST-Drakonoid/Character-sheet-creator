<%- include('partials/header') %>

<main class="page">
    <section class="content-card">
        <h1><%= title %></h1>

        <p>
            Welcome to the Silly Space Supply Depot, your one-stop shop for all
            your intergalactic needs. Quality is not guaranteed, but adventure is.
        </p>

        <div class="card-grid">

            <article class="mini-card">
                <h3>🚀 Pocket Rocket</h3>
                <p>
                    A compact personal spacecraft capable of reaching speeds that
                    are technically "very fast."
                </p>
                <p class="price">$49.99</p>
            </article>

            <article class="mini-card">
                <h3>👽 Universal Alien Translator</h3>
                <p>
                    Converts alien languages into awkward small talk and occasional
                    insults.
                </p>
                <p class="price">$24.99</p>
            </article>

            <article class="mini-card">
                <h3>🪐 Planet Polish</h3>
                <p>
                    Restores that showroom shine to tired-looking planets.
                </p>
                <p class="price">$12.99</p>
            </article>

            <article class="mini-card">
                <h3>🛰️ Satellite-on-a-Stick</h3>
                <p>
                    Improves reception by 3% when waved dramatically at the sky.
                </p>
                <p class="price">$19.99</p>
            </article>

            <article class="mini-card">
                <h3>🌌 Portable Wormhole Kit</h3>
                <p>
                    Travel anywhere instantly. Return trip sold separately.
                </p>
                <p class="price">$199.99</p>
            </article>

            <article class="mini-card">
                <h3>🛸 UFO Parking Permit</h3>
                <p>
                    Valid in most star systems except Earth and Alpha Centauri.
                </p>
                <p class="price">$7.99</p>
            </article>

            <article class="mini-card">
                <h3>🌕 Moon Cheese Sampler</h3>
                <p>
                    Aged in vacuum conditions for a truly astronomical flavor.
                </p>
                <p class="price">$14.99</p>
            </article>

            <article class="mini-card">
                <h3>🤖 Robot Butler 3000</h3>
                <p>
                    Cleans your ship and occasionally questions your life choices.
                </p>
                <p class="price">$999.99</p>
            </article>

            <article class="mini-card">
                <h3>🪐 Pluto Appreciation Certificate</h3>
                <p>
                    Officially recognizes Pluto as "still important."
                </p>
                <p class="price">$3.99</p>
            </article>

        </div>
    </section>
</main>

<%- include('partials/footer') %>