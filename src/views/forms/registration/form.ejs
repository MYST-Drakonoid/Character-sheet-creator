<%- include('../../partials/header') %>

<main>
    <!-- Sign Up page title. -->
    <h1>Register</h1>

```
<!-- New user registration form. -->
<form method="POST" action="/register" class="registration-form">

    <!-- User display name. -->
    <div class="form-group">
        <label for="name">Name</label>

        <input
            type="text"
            id="name"
            name="name"
            minlength="2"
            placeholder="Enter your name"
            required
        >
    </div>

    <!-- Primary email address used for authentication and account recovery. -->
    <div class="form-group">
        <label for="email">Email</label>

        <input
            type="email"
            id="email"
            name="email"
            placeholder="Enter your email address"
            required
        >
    </div>

    <!-- Email confirmation to reduce account creation errors. -->
    <div class="form-group">
        <label for="emailConfirm">Confirm Email</label>

        <input
            type="email"
            id="emailConfirm"
            name="emailConfirm"
            placeholder="Confirm your email address"
            required
        >
    </div>

    <!-- Password requirements are enforced on both the client and server. -->
    <div class="form-group">
        <label for="password">Password</label>

        <input
            type="password"
            id="password"
            name="password"
            minlength="8"
            pattern="(?=.*[0-9])(?=.*[!@#$%^&*]).*"
            placeholder="Enter your password"
            required
        >

        <div class="help-text">
            Must be at least 8 characters with a number and special character.
        </div>
    </div>

    <!-- Password confirmation helps prevent accidental typos. -->
    <div class="form-group">
        <label for="passwordConfirm">Password Confirmation</label>

        <input
            type="password"
            id="passwordConfirm"
            name="passwordConfirm"
            minlength="8"
            pattern="(?=.*[0-9])(?=.*[!@#$%^&*]).*"
            placeholder="Confirm your password"
            required
        >

        <div class="help-text">
            Please confirm your password.
        </div>
    </div>

    <!-- Submit registration information to create a new account. -->
    <button type="submit">Register</button>
</form>
```

</main>

